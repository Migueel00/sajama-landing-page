---
import Layout from '../layouts/Layout.astro';
import Counter from '../components/Counter';
---

<Layout title="Sajama Landing">
  <main class="min-h-screen flex flex-col items-center justify-center gap-8 p-8">
    <div class="text-center">
      <h1 class="text-5xl font-bold tracking-tight text-indigo-600">
        Sajama Landing
      </h1>
      <p class="mt-3 text-lg text-gray-500">
        Astro + Tailwind CSS + React TS — ready to build.
      </p>
    </div>

    <div class="flex flex-col items-center gap-2">
      <p class="text-sm text-gray-400 uppercase tracking-widest">Componente React interactivo</p>
      <Counter client:load initialCount={0} />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 w-full max-w-2xl text-sm">
      <div class="rounded-xl border border-gray-200 p-4">
        <p class="font-semibold text-indigo-500">Astro 5</p>
        <p class="text-gray-500 mt-1">Islands architecture, zero JS por defecto.</p>
      </div>
      <div class="rounded-xl border border-gray-200 p-4">
        <p class="font-semibold text-indigo-500">Tailwind v4</p>
        <p class="text-gray-500 mt-1">Utility-first CSS con Vite plugin.</p>
      </div>
      <div class="rounded-xl border border-gray-200 p-4">
        <p class="font-semibold text-indigo-500">React 19 + TS</p>
        <p class="text-gray-500 mt-1">Componentes interactivos tipados.</p>
      </div>
    </div>
  </main>
</Layout>
