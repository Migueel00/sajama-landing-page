---
const proyectoTipos = [
  'Reforma integral',
  'Obra nueva residencial',
  'Obra pública / civil',
  'Rehabilitación de edificios',
  'Nave industrial',
  'Otro',
];
---

<section id="contacto" class="max-w-[1240px] mx-auto px-5 sm:px-8 lg:px-10 py-20 md:py-28 lg:py-[110px]">
  <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-10 lg:gap-20">
    <div>
      <div class="text-xs tracking-[0.18em] uppercase text-brand font-semibold mb-5">Hablemos</div>
      <h2 class="text-3xl sm:text-4xl md:text-[44px] font-bold tracking-[-0.025em] leading-[1.04] mb-7">
        Pide tu presupuesto sin compromiso.
      </h2>
      <p class="text-base md:text-[17px] leading-[1.6] text-[#45484c] mb-10 max-w-[38ch]">
        Cuéntanos qué tienes en mente. Te respondemos en menos de 48 horas laborables con una valoración inicial.
      </p>
      <div class="flex flex-col gap-6 border-t border-[#e8e6e0] pt-8">
        <div>
          <div class="text-xs uppercase tracking-[0.12em] text-[#9a9d9f] font-semibold mb-1.5">Teléfono</div>
          <a href="tel:+34631516790" class="text-lg font-semibold hover:text-brand transition-colors">631 51 67 90</a>
        </div>
        <div>
          <div class="text-xs uppercase tracking-[0.12em] text-[#9a9d9f] font-semibold mb-1.5">Email</div>
          <a href="mailto:sajamarehabilitaciones@gmail.com" class="text-lg font-semibold hover:text-brand transition-colors break-all">
            sajamarehabilitaciones@gmail.com
          </a>
        </div>
        <div>
          <div class="text-xs uppercase tracking-[0.12em] text-[#9a9d9f] font-semibold mb-1.5">Oficina</div>
          <div class="text-lg font-semibold">Calle Sancho Enea 10, 2º Dcha.</div>
          <div class="text-sm text-[#6f7378] mt-0.5">20100 Errenteria, Gipuzkoa</div>
        </div>
      </div>
    </div>

    <div class="bg-white border border-[#ecebe5] rounded-[22px] p-6 sm:p-9 md:p-11 shadow-[0_30px_70px_-40px_rgba(20,45,80,0.35)]">
      <div id="contact-success" class="hidden flex-col items-start justify-center min-h-[420px]">
        <div class="w-[52px] h-[52px] rounded-full bg-brand text-white flex items-center justify-center text-2xl mb-6">
          ✓
        </div>
        <h3 class="text-2xl md:text-[28px] font-bold tracking-[-0.02em] mb-3">Recibido, gracias.</h3>
        <p class="text-base text-[#45484c] leading-[1.55]">
          Te contactaremos en menos de 48 horas laborables. Si es urgente, llámanos al
          <a href="tel:+34631516790" class="font-semibold text-brand">631 51 67 90</a>.
        </p>
      </div>

      <form id="contact-form" class="flex flex-col gap-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <label class="flex flex-col gap-2">
            <span class="text-[13px] font-semibold text-[#45484c]">Nombre</span>
            <input
              required
              type="text"
              name="nombre"
              autocomplete="name"
              class="border border-[#d6d4cd] bg-white rounded-[10px] px-3.5 py-[13px] text-[15px] text-[#16181b] outline-none focus:border-brand"
            />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-[13px] font-semibold text-[#45484c]">Teléfono</span>
            <input
              required
              type="tel"
              name="telefono"
              autocomplete="tel"
              class="border border-[#d6d4cd] bg-white rounded-[10px] px-3.5 py-[13px] text-[15px] text-[#16181b] outline-none focus:border-brand"
            />
          </label>
        </div>
        <label class="flex flex-col gap-2">
          <span class="text-[13px] font-semibold text-[#45484c]">Email</span>
          <input
            required
            type="email"
            name="email"
            autocomplete="email"
            class="border border-[#d6d4cd] bg-white rounded-[10px] px-3.5 py-[13px] text-[15px] text-[#16181b] outline-none focus:border-brand"
          />
        </label>
        <label class="flex flex-col gap-2">
          <span class="text-[13px] font-semibold text-[#45484c]">Tipo de proyecto</span>
          <select
            name="tipo_de_proyecto"
            class="border border-[#d6d4cd] bg-white rounded-[10px] px-3.5 py-[13px] text-[15px] text-[#16181b] outline-none focus:border-brand"
          >
            {proyectoTipos.map((tipo) => <option>{tipo}</option>)}
          </select>
        </label>
        <label class="flex flex-col gap-2">
          <span class="text-[13px] font-semibold text-[#45484c]">Cuéntanos</span>
          <textarea
            rows="4"
            name="mensaje"
            class="border border-[#d6d4cd] bg-white rounded-[10px] px-3.5 py-[13px] text-[15px] text-[#16181b] outline-none focus:border-brand resize-y"
          ></textarea>
        </label>
        <p id="contact-error" class="hidden text-sm text-red-600 leading-[1.5]">
          No se ha podido enviar la solicitud. Inténtalo de nuevo o llámanos al
          <a href="tel:+34631516790" class="font-semibold underline">631 51 67 90</a>.
        </p>
        <button
          type="submit"
          class="bg-brand hover:bg-brand-dark transition-colors text-white border-none rounded-[10px] py-4 text-[15px] font-semibold tracking-[0.01em] cursor-pointer disabled:opacity-60 disabled:cursor-wait"
        >
          Enviar solicitud
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  const errorBox = document.getElementById('contact-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando…';
    errorBox?.classList.add('hidden');

    try {
      const res = await fetch('https://formsubmit.co/ajax/sajamarehabilitaciones@gmail.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          ...Object.fromEntries(new FormData(form)),
          _subject: 'Nueva solicitud de presupuesto — sajama.es',
          _template: 'table',
        }),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      form.style.display = 'none';
      if (success) success.style.display = 'flex';
    } catch {
      errorBox?.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Enviar solicitud';
    }
  });
</script>
